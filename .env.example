# ─────────────────────────────────────────────────
#  TMDB API Credentials
#  Dapatkan dari: https://www.themoviedb.org/settings/api
# ─────────────────────────────────────────────────

# [WAJIB] API Read Access Token (v4 auth) — untuk search film & auth flow
# Ambil dari: Settings → API → "API Read Access Token (v4 auth)"
TMDB_ACCESS_TOKEN=your_read_access_token_here

# [AUTO] User Access Token — untuk write (buat list & tambah film)
# Token ini akan otomatis diisi oleh program saat pertama kali dijalankan.
# Anda TIDAK perlu mengisinya secara manual.
TMDB_USER_ACCESS_TOKEN=

# [AUTO] Account ID TMDB — diisi otomatis juga
TMDB_ACCOUNT_ID=

# ─────────────────────────────────────────────────
#  Optional Settings
# ─────────────────────────────────────────────────

# Bahasa default untuk hasil pencarian TMDB (default: en-US)
TMDB_LANGUAGE=en-US

# Delay antar request ke Letterboxd dalam detik (default: 1.0)
SCRAPE_DELAY=1.0
